DOMAIN=proxy.example.com
USERNAME=your_user
PASSWORD=change_this_strong_password
DECOY_DOMAIN=www.example.com

# Optional. If empty, Caddy still obtains certificates through Let's Encrypt.
EMAIL=admin@example.com

# Optional. Change only when ports 80/443 are already occupied on the host.
HTTP_PORT=80
HTTPS_PORT=443
